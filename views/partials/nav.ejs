<header class="navbar glass" style="height:auto; flex-direction:column; padding:0;">
  <!-- Top Nav Row -->
  <div class="nav-inner" style="padding:12px 24px; height:64px;">
    <a href="/" class="nav-logo">
      <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
        <path
          d="M16 1C7.716 1 1 7.716 1 16s6.716 15 15 15 15-6.716 15-15S24.284 1 16 1zm6.95 22.661c-.634 1.02-1.932 1.339-2.952.705-.04-.025-.08-.052-.118-.08-1.59-1.13-3.559-1.79-5.88-1.79s-4.29.66-5.88 1.79c-.038.028-.078.055-.118.08a2.136 2.136 0 0 1-2.952-.705A2.136 2.136 0 0 1 5.755 20.7c.04-.025.08-.052.118-.08C8.193 19.01 11.86 18 16 18s7.807 1.01 10.127 2.62c.038.028.078.055.118.08a2.136 2.136 0 0 1 .705 2.961zM16 15a5 5 0 1 1 0-10 5 5 0 0 1 0 10z" />
      </svg>
      airbnb
    </a>

    <!-- Center Category Tabs -->
    <div class="category-tabs">
      <a href="/"
        class="category-tab <%= (typeof currentPage !== 'undefined' && (currentPage === 'index' || currentPage === 'Home')) ? 'active' : '' %>">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        <span>Homes</span>
      </a>
      <a href="/experiences"
        class="category-tab <%= (typeof currentPage !== 'undefined' && currentPage === 'experiences') ? 'active' : '' %>">
        <span class="tab-new-badge">NEW</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 8v4l3 3" />
        </svg>
        <span>Experiences</span>
      </a>
      <a href="/services"
        class="category-tab <%= (typeof currentPage !== 'undefined' && currentPage === 'services') ? 'active' : '' %>">
        <span class="tab-new-badge">NEW</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        <span>Services</span>
      </a>
    </div>

    <!-- Right Side -->
    <ul class="nav-links">
      <% if (isLoggedIn) { %>
        <% if (userRole !=='admin' ) { %>
          <li>
            <a href="/homes" class="nav-link <%= currentPage === 'Home' ? 'active' : '' %>">Explore</a>
          </li>
          <li>
            <a href="/favourites" class="nav-link <%= currentPage === 'favourites' ? 'active' : '' %>">Wishlist</a>
          </li>
          <li>
            <a href="/bookings" class="nav-link <%= currentPage === 'bookings' ? 'active' : '' %>">Trips</a>
          </li>
          <% } %>
            <% if (userRole==='admin' ) { %>
              <li>
                <a href="/host/host-home-list" class="nav-link <%= currentPage === 'host-homes' ? 'active' : '' %>">Your
                  Listings</a>
              </li>
              <li>
                <a href="/host/add-home" class="nav-link <%= currentPage === 'addHome' ? 'active' : '' %>">List a
                  Home</a>
              </li>
              <% } %>
                <li style="display:flex; align-items:center; gap:10px; margin-left:8px;">
                  <span
                    style="font-size:0.8125rem; color:var(--text-secondary); display:flex; align-items:center; gap:4px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </svg>
                    <%= userName %>
                      <% if (userRole==='admin' ) { %>
                        <span class="badge badge-superhost" style="font-size:0.625rem; padding:2px 6px;">Admin</span>
                        <% } %>
                  </span>
                  <form action="/logout" method="POST" style="margin:0;">
                    <button type="submit" class="nav-auth-btn">Sign out</button>
                  </form>
                </li>
                <% } else { %>
                  <li>
                    <a href="/login" class="nav-auth-btn" style="background:#FF385C;">Sign in</a>
                  </li>
                  <% } %>
    </ul>
  </div>

  <!-- Search Bar (only on index page) -->
  <% if (typeof currentPage !=='undefined' && currentPage==='index' ) { %>
    <div class="search-bar-wrapper">
      <div class="search-bar" id="searchBar">
        <!-- WHERE -->
        <div class="search-field search-field-main" onclick="togglePanel('wherePanel')">
          <label>Where</label>
          <input type="text" id="whereInput" placeholder="Search destinations" autocomplete="off"
            onclick="event.stopPropagation(); togglePanel('wherePanel')" oninput="filterLocations()" />
        </div>
        <div class="search-divider"></div>
        <!-- WHEN -->
        <div class="search-field" onclick="togglePanel('whenPanel')">
          <label>When</label>
          <input type="text" id="whenDisplay" placeholder="Add dates" readonly
            onclick="event.stopPropagation(); togglePanel('whenPanel')" />
        </div>
        <div class="search-divider"></div>
        <!-- WHO -->
        <div class="search-field" onclick="togglePanel('whoPanel')">
          <label>Who</label>
          <input type="text" id="whoDisplay" placeholder="Add guests" readonly
            onclick="event.stopPropagation(); togglePanel('whoPanel')" />
        </div>
        <a href="/homes" class="search-btn" id="searchBtn" onclick="handleSearch(event)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
        </a>
      </div>

      <!-- WHERE Panel -->
      <div class="search-panel" id="wherePanel">
        <div class="search-panel-header">Popular destinations</div>
        <div id="locationList">
          <% if (typeof registeredHomes !=='undefined' ) { %>
            <% const locations=[...new Set(registeredHomes.map(h=> h.location))]; %>
              <% locations.forEach(loc=> { %>
                <div class="location-option" onclick="selectLocation('<%= loc %>')">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                  <span>
                    <%= loc %>
                  </span>
                </div>
                <% }) %>
                  <% } %>
        </div>
      </div>

      <!-- WHEN Panel -->
      <div class="search-panel search-panel-dates" id="whenPanel">
        <div class="search-panel-header">Select dates</div>
        <div class="date-picker-row">
          <div class="date-picker-field">
            <label>Check-in</label>
            <input type="date" id="checkInDate" onchange="updateDateDisplay()" />
          </div>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2"
            style="flex-shrink:0;margin-top:18px;">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
          <div class="date-picker-field">
            <label>Check-out</label>
            <input type="date" id="checkOutDate" onchange="updateDateDisplay()" />
          </div>
        </div>
      </div>

      <!-- WHO Panel -->
      <div class="search-panel search-panel-who" id="whoPanel">
        <div class="search-panel-header">Guests</div>
        <div class="guest-row">
          <div>
            <div class="guest-row-label">Adults</div>
            <div class="guest-row-sub">Ages 13+</div>
          </div>
          <div class="guest-counter">
            <button class="counter-btn" onclick="changeCount('adults', -1)">−</button>
            <span id="adultsCount">1</span>
            <button class="counter-btn" onclick="changeCount('adults', 1)">+</button>
          </div>
        </div>
        <div class="guest-row">
          <div>
            <div class="guest-row-label">Children</div>
            <div class="guest-row-sub">Ages 2–12</div>
          </div>
          <div class="guest-counter">
            <button class="counter-btn" onclick="changeCount('children', -1)">−</button>
            <span id="childrenCount">0</span>
            <button class="counter-btn" onclick="changeCount('children', 1)">+</button>
          </div>
        </div>
        <div class="guest-row" style="border-bottom:none;">
          <div>
            <div class="guest-row-label">Infants</div>
            <div class="guest-row-sub">Under 2</div>
          </div>
          <div class="guest-counter">
            <button class="counter-btn" onclick="changeCount('infants', -1)">−</button>
            <span id="infantsCount">0</span>
            <button class="counter-btn" onclick="changeCount('infants', 1)">+</button>
          </div>
        </div>
      </div>
    </div>

    <script>
      let guests = { adults: 1, children: 0, infants: 0 };

      function togglePanel(id) {
        const panels = document.querySelectorAll('.search-panel');
        panels.forEach(p => {
          if (p.id !== id) p.classList.remove('open');
        });
        document.getElementById(id).classList.toggle('open');
      }

      function selectLocation(loc) {
        document.getElementById('whereInput').value = loc;
        document.getElementById('wherePanel').classList.remove('open');
      }

      function filterLocations() {
        const val = document.getElementById('whereInput').value.toLowerCase();
        document.querySelectorAll('.location-option').forEach(opt => {
          const text = opt.querySelector('span').textContent.toLowerCase();
          opt.style.display = text.includes(val) ? 'flex' : 'none';
        });
      }

      function updateDateDisplay() {
        const ci = document.getElementById('checkInDate').value;
        const co = document.getElementById('checkOutDate').value;
        const display = document.getElementById('whenDisplay');
        if (ci && co) {
          const ciDate = new Date(ci).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
          const coDate = new Date(co).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
          display.value = ciDate + ' → ' + coDate;
        } else if (ci) {
          display.value = new Date(ci).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
        }
      }

      function changeCount(type, delta) {
        guests[type] = Math.max(type === 'adults' ? 1 : 0, guests[type] + delta);
        guests[type] = Math.min(10, guests[type]);
        document.getElementById(type + 'Count').textContent = guests[type];
        updateGuestDisplay();
      }

      function updateGuestDisplay() {
        const total = guests.adults + guests.children;
        let text = total + ' guest' + (total !== 1 ? 's' : '');
        if (guests.infants > 0) text += ', ' + guests.infants + ' infant' + (guests.infants !== 1 ? 's' : '');
        document.getElementById('whoDisplay').value = text;
      }

      function handleSearch(e) {
        e.preventDefault();
        window.location.href = '/homes';
      }

      // Close panels when clicking outside
      document.addEventListener('click', function (e) {
        if (!e.target.closest('.search-bar-wrapper')) {
          document.querySelectorAll('.search-panel').forEach(p => p.classList.remove('open'));
        }
      });
    </script>
    <% } %>
</header>