<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav') %>

      <div class="page-container">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:32px;">
          <div>
            <h2 class="page-title">Your listings</h2>
            <p class="page-subtitle">
              <%= registeredHomes.length %> home<%= registeredHomes.length !==1 ? 's' : '' %> listed
            </p>
          </div>
          <a href="/host/add-home" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add new
          </a>
        </div>

        <% if (registeredHomes && registeredHomes.length> 0) { %>
          <div class="grid grid-3">
            <% registeredHomes.forEach((home, index)=> { %>
              <div class="card animate-fade-in-up stagger-<%= (index % 6) + 1 %>">
                <div class="card-image-wrapper">
                  <% if (home.photoUrl) { %>
                    <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>">
                    <% } else { %>
                      <div class="no-image">No image available</div>
                      <% } %>
                        <div class="card-badge badge-verified">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="3">
                            <polyline points="20 6 9 17 4 12" />
                          </svg>
                          Active
                        </div>
                </div>
                <div class="card-body">
                  <div class="card-title">
                    <%= home.houseName %>
                  </div>
                  <div class="card-location">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                    <%= home.location %>
                  </div>
                  <div class="card-meta" style="margin-bottom:12px;">
                    <div class="card-price">₹<%= home.price.toLocaleString() %> <span>/ night</span></div>
                    <div class="card-rating">
                      <svg viewBox="0 0 24 24">
                        <path
                          d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                      </svg>
                      <%= home.rating %>
                    </div>
                  </div>
                  <div class="host-actions">
                    <a href="/host/edit-home/<%= home._id %>?editing=true" class="btn btn-outline btn-sm"
                      style="flex:1;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                      </svg>
                      Edit
                    </a>
                    <form action="/host/delete-home/<%= home._id %>" method="POST" style="flex:1;">
                      <button type="submit" class="btn btn-danger btn-sm btn-full">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <polyline points="3 6 5 6 21 6" />
                          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                        </svg>
                        Delete
                      </button>
                    </form>
                  </div>
                </div>
              </div>
              <% }) %>
          </div>
          <% } else { %>
            <div class="empty-state">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
              </svg>
              <h3>No listings yet</h3>
              <p>Start hosting and earn by sharing your space.</p>
              <a href="/host/add-home" class="btn btn-primary">Create your first listing</a>
            </div>
            <% } %>
      </div>

  </body>

  </html>