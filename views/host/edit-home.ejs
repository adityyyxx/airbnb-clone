<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav') %>

      <div class="page-container" style="max-width:640px;">
        <div class="page-header" style="text-align:center;">
          <h2 class="page-title">
            <%= editing ? "Edit your listing" : "List your home" %>
          </h2>
          <p class="page-subtitle">
            <%= editing ? "Update the details below" : "Share your space with travelers around the world" %>
          </p>
        </div>

        <div class="animate-fade-in-up"
          style="background:var(--bg-primary); border-radius:var(--radius-md); padding:32px; box-shadow:var(--shadow-md); border:1px solid var(--border-light);">
          <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST">
            <input type="hidden" name="id" value="<%= editing ? home._id : '' %>" />

            <div class="form-group">
              <label class="form-label">
                <span style="display:flex;align-items:center;gap:6px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                  </svg>
                  Home name
                </span>
              </label>
              <input type="text" name="houseName" value="<%= editing ? home.houseName : '' %>" class="form-input"
                placeholder="e.g. Cozy Mountain Retreat" required />
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
              <div class="form-group">
                <label class="form-label">
                  <span style="display:flex;align-items:center;gap:6px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="12" y1="1" x2="12" y2="23" />
                      <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                    Price / night (₹)
                  </span>
                </label>
                <input type="number" name="price" value="<%= editing ? home.price : '' %>" class="form-input"
                  placeholder="2500" required />
              </div>
              <div class="form-group">
                <label class="form-label">
                  <span style="display:flex;align-items:center;gap:6px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polygon
                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                    Rating
                  </span>
                </label>
                <input type="number" name="rating" value="<%= editing ? home.rating : '' %>" class="form-input"
                  placeholder="4.5" step="0.1" min="0" max="5" required />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">
                <span style="display:flex;align-items:center;gap:6px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                  Location
                </span>
              </label>
              <input type="text" name="location" value="<%= editing ? home.location : '' %>" class="form-input"
                placeholder="e.g. Manali, Himachal Pradesh" required />
            </div>

            <div class="form-group">
              <label class="form-label">
                <span style="display:flex;align-items:center;gap:6px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <polyline points="21 15 16 10 5 21" />
                  </svg>
                  Photo URL
                </span>
              </label>
              <input type="url" name="photoUrl" value="<%= editing ? home.photoUrl : '' %>" class="form-input"
                placeholder="https://images.example.com/photo.jpg" />
            </div>

            <div class="form-group">
              <label class="form-label">
                <span style="display:flex;align-items:center;gap:6px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="17" y1="10" x2="3" y2="10" />
                    <line x1="21" y1="6" x2="3" y2="6" />
                    <line x1="21" y1="14" x2="3" y2="14" />
                    <line x1="17" y1="18" x2="3" y2="18" />
                  </svg>
                  Description
                </span>
              </label>
              <textarea name="description" class="form-input"
                placeholder="Tell travelers what makes your home special..."
                rows="4"><%= editing ? home.description : '' %></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-full" style="padding:14px; margin-top:8px;">
              <%= editing ? "Save changes" : "Publish listing" %>
            </button>
          </form>
        </div>
      </div>

  </body>

  </html>