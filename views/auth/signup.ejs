<%- include('../partials/head') %>
    <style>
        :root {
            --auth-bg: #000000;
            --card-bg: #121212;
            --text-main: #ffffff;
            --text-muted: #a0a0a0;
            --btn-primary: #e2e2e2;
            --btn-secondary: #262626;
            --border-color: #333333;
            --accent: #FF385C;
        }

        body {
            background-color: var(--auth-bg);
            background-image:
                linear-gradient(to right, #ffffff0a 1px, transparent 1px),
                linear-gradient(to bottom, #ffffff0a 1px, transparent 1px);
            background-size: 40px 40px;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        .auth-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .auth-card {
            background: var(--card-bg);
            width: 100%;
            max-width: 360px;
            border-radius: 20px;
            padding: 24px 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            text-align: center;
            border: 1px solid var(--border-color);
        }

        .auth-card h1 {
            color: var(--text-main);
            font-size: 24px;
            font-weight: 700;
            margin: 0 0 8px;
        }

        .auth-card .subtitle {
            color: var(--text-muted);
            font-size: 14px;
            line-height: 1.4;
            margin-bottom: 24px;
        }

        .auth-form {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
            text-align: left;
        }

        .form-group label {
            color: var(--text-main);
            font-size: 13px;
            font-weight: 600;
        }

        .form-input {
            width: 100%;
            background: #1e1e1e;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 12px 14px;
            color: white;
            font-size: 14px;
            box-sizing: border-box;
        }

        .form-input::placeholder {
            color: #555;
        }

        .form-input:focus {
            outline: none;
            border-color: #555;
        }

        .auth-btn {
            width: 100%;
            padding: 14px;
            border-radius: 10px;
            border: none;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            transition: transform 0.1s, opacity 0.2s;
        }

        .btn-primary {
            background: var(--btn-primary);
            color: #444;
        }

        .btn-secondary {
            background: var(--btn-secondary);
            color: var(--text-main);
            border: 1px solid var(--border-color);
        }

        .auth-footer {
            margin-top: 24px;
            color: var(--text-muted);
            font-size: 14px;
            text-align: center;
        }

        .auth-footer a {
            color: var(--text-main);
            font-weight: 700;
            text-decoration: none;
            border-bottom: 2px solid var(--text-main);
            padding-bottom: 2px;
            margin-left: 4px;
        }

        .error-box {
            background: #4a0000;
            color: #ffbaba;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            border: 1px solid #ff4444;
            text-align: center;
        }
    </style>
    </head>

    <body>
        <div class="auth-container">
            <div class="auth-card">


                <h1>Sign Up</h1>
                <p class="subtitle">Create a new account to get started</p>

                <% if (errorMessage) { %>
                    <div class="error-box">
                        <%= errorMessage %>
                    </div>
                    <% } %>

                        <!-- Option 1: Google -->
                        <a href="/auth/google" class="auth-btn btn-primary"
                            style="background: white; color: #000; margin-bottom: 20px;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path
                                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                    fill="#4285F4" />
                                <path
                                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                    fill="#34A853" />
                                <path
                                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                    fill="#FBBC05" />
                                <path
                                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                    fill="#EA4335" />
                            </svg>
                            Sign up with Google
                        </a>

                        <div
                            style="position: relative; height: 1px; background: #333; margin: 24px 0; display: flex; align-items: center; justify-content: center;">
                            <div
                                style="background: #000; color: #666; padding: 0 12px; font-size: 11px; font-weight: 700; letter-spacing: 1px; position: absolute;">
                                OR</div>
                        </div>

                        <form action="/signup" method="POST" class="auth-form">
                            <div class="form-group">
                                <label>Username</label>
                                <input type="text" name="username" class="form-input" placeholder="Enter your username"
                                    required />
                            </div>

                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" name="email" class="form-input" placeholder="Enter your email"
                                    required />
                            </div>

                            <div class="form-group">
                                <label>Password</label>
                                <input type="password" name="password" class="form-input"
                                    placeholder="Enter your password" required />
                            </div>

                            <input type="hidden" name="confirmPassword" id="confirmPasswordHidden" />

                            <button type="submit" class="auth-btn btn-primary">Sign Up</button>

                            <a href="/login" class="auth-btn btn-secondary">
                                <span>←</span> Back to Sign In
                            </a>
                        </form>
            </div>

            <div class="auth-footer">
                Already have an account? <a href="/login">Sign in</a>
            </div>
        </div>

        <script>
            document.querySelector('form').addEventListener('submit', function () {
                const pwd = document.querySelector('input[name="password"]').value;
                const confirm = document.getElementById('confirmPasswordHidden');
                if (confirm) confirm.value = pwd;
            });
        </script>
    </body>

    </html>