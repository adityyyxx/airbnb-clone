<%- include('../partials/head') %>
  <style>
    :root {
      --auth-bg: #000000;
      --card-bg: #121212;
      --text-main: #ffffff;
      --text-muted: #a0a0a0;
      --btn-primary: #e2e2e2;
      --btn-secondary: #262626;
      --border-color: #333333;
      --accent: #FF385C;
    }

    body {
      background-color: var(--auth-bg);
      background-image:
        linear-gradient(to right, #ffffff0a 1px, transparent 1px),
        linear-gradient(to bottom, #ffffff0a 1px, transparent 1px);
      background-size: 40px 40px;
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .auth-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 20px;
    }

    .auth-card {
      background: var(--card-bg);
      width: 100%;
      max-width: 400px;
      border-radius: 24px;
      padding: 40px 32px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
      text-align: center;
      border: 1px solid var(--border-color);
    }



    .auth-card h1 {
      color: var(--text-main);
      font-size: 32px;
      font-weight: 700;
      margin: 0 0 12px;
    }

    .auth-card .subtitle {
      color: var(--text-muted);
      font-size: 16px;
      line-height: 1.5;
      margin-bottom: 32px;
    }

    .auth-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
      text-align: left;
    }

    .form-group label {
      color: var(--text-main);
      font-size: 14px;
      font-weight: 600;
    }

    .form-input {
      width: 100%;
      background: #1e1e1e;
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 14px 16px;
      color: white;
      font-size: 14px;
      box-sizing: border-box;
    }

    .form-input::placeholder {
      color: #555;
    }

    .form-input:focus {
      outline: none;
      border-color: #555;
    }

    .auth-btn {
      width: 100%;
      padding: 16px;
      border-radius: 12px;
      border: none;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      text-decoration: none;
      transition: transform 0.1s, opacity 0.2s;
    }

    .btn-primary {
      background: var(--btn-primary);
      color: #444;
    }

    .btn-secondary {
      background: var(--btn-secondary);
      color: var(--text-main);
      border: 1px solid var(--border-color);
    }

    .divider-container {
      position: relative;
      height: 1px;
      background: #333;
      margin: 32px 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .divider-text {
      background: #000;
      color: #666;
      padding: 0 12px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      position: absolute;
      vertical-align: middle;
    }

    .auth-footer {
      margin-top: 32px;
      color: var(--text-muted);
      font-size: 16px;
      text-align: center;
    }

    .auth-footer a {
      color: var(--text-main);
      font-weight: 700;
      text-decoration: none;
      border-bottom: 2px solid var(--text-main);
      padding-bottom: 2px;
      margin-left: 4px;
    }

    #emailForm {
      display: none;
      margin-top: 24px;
    }

    .error-box {
      background: #4a0000;
      color: #ffbaba;
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 14px;
      border: 1px solid #ff4444;
      text-align: center;
    }
  </style>
  </head>

  <body>
    <div class="auth-container">
      <div class="auth-card">


        <h1>Sign In</h1>
        <p class="subtitle">Welcome back! Please sign in to your account.</p>

        <% if (errorMessage) { %>
          <div class="error-box">
            <%= errorMessage %>
          </div>
          <% } %>

            <!-- Option 1: Google -->
            <a href="/auth/google" class="auth-btn btn-primary" style="background: white; color: #000;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                  fill="#4285F4" />
                <path
                  d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                  fill="#34A853" />
                <path
                  d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                  fill="#FBBC05" />
                <path
                  d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                  fill="#EA4335" />
              </svg>
              Continue with Google
            </a>

            <div class="divider-container">
              <div class="divider-text">OR</div>
            </div>

            <!-- Option 2: Email Button -->
            <button class="auth-btn btn-secondary" onclick="showEmailForm()" id="emailBtn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              Sign in with Email
            </button>

            <!-- Sign In Form -->
            <div id="emailForm">
              <form action="/login" method="POST" class="auth-form">
                <div class="form-group">
                  <label>Username / Email</label>
                  <input type="text" name="username" class="form-input" placeholder="Enter your email or username"
                    required />
                </div>
                <div class="form-group">
                  <label>Password</label>
                  <input type="password" name="password" class="form-input" placeholder="Enter your password"
                    required />
                </div>
                <button type="submit" class="auth-btn btn-primary" style="background: var(--accent); color: white;">Sign
                  in</button>
              </form>
            </div>
      </div>

      <div class="auth-footer">
        Don't have an account? <a href="/signup">Sign up</a>
      </div>
    </div>

    <input type="hidden" id="hasError" value="<%= errorMessage ? 'true' : '' %>" />
    <script>
      function showEmailForm() {
        var form = document.getElementById('emailForm');
        var btn = document.getElementById('emailBtn');
        if (form) form.style.display = 'block';
        if (btn) btn.style.display = 'none';
      }

      if (document.getElementById('hasError').value === 'true') {
        showEmailForm();
      }
    </script>
  </body>

  </html>