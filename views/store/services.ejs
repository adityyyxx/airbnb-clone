<%- include('../partials/head') %>
    </head>

    <body>
        <%- include('../partials/nav') %>

            <div class="page-container" style="padding-top:24px;">

                <!-- Category Icons Row -->
                <div class="services-hero">
                    <h1 class="services-main-title">Services in India</h1>
                    <div class="service-categories-row">
                        <% categoryOrder.forEach((cat, i)=> { %>
                            <a href="#section-<%= i %>" class="service-cat-icon"
                                onclick="scrollToSection(event, 'section-<%= i %>')">
                                <div class="service-cat-img">
                                    <% if (cat==='Photography' ) { %>
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="1.5">
                                            <path
                                                d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                            <circle cx="12" cy="13" r="4" />
                                        </svg>
                                        <% } else if (cat==='Chefs' ) { %>
                                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="1.5">
                                                <path
                                                    d="M12 2C6.48 2 2 6 2 10.5c0 2.5 1.5 4.5 3 5.5v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4c1.5-1 3-3 3-5.5C22 6 17.52 2 12 2z" />
                                                <line x1="8" y1="14" x2="8" y2="18" />
                                                <line x1="12" y1="14" x2="12" y2="18" />
                                                <line x1="16" y1="14" x2="16" y2="18" />
                                            </svg>
                                            <% } else if (cat==='Massage' ) { %>
                                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="1.5">
                                                    <path
                                                        d="M6 15c-2-1-4-3.5-4-6.5a6.5 6.5 0 0 1 13 0c0 1-.3 2-.7 2.8" />
                                                    <path d="M9 18c-2-1-4-3.5-4-6.5" />
                                                    <circle cx="17" cy="8" r="3" />
                                                    <path d="M14 14l3 8" />
                                                    <path d="M20 14l-3 8" />
                                                </svg>
                                                <% } else if (cat==='Training' ) { %>
                                                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="1.5">
                                                        <path d="M18 8h1a4 4 0 0 1 0 8h-1" />
                                                        <path d="M6 8H5a4 4 0 0 0 0 8h1" />
                                                        <line x1="6" y1="12" x2="18" y2="12" />
                                                        <line x1="9" y1="8" x2="9" y2="16" />
                                                        <line x1="15" y1="8" x2="15" y2="16" />
                                                    </svg>
                                                    <% } else if (cat==='Make-up' ) { %>
                                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                                            stroke="currentColor" stroke-width="1.5">
                                                            <path
                                                                d="M9.5 2l4 7.5L18 12l-4.5 2.5L9.5 22l-4-7.5L1 12l4.5-2.5z" />
                                                            <circle cx="18" cy="6" r="3" />
                                                        </svg>
                                                        <% } else if (cat==='Hair' ) { %>
                                                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="1.5">
                                                                <circle cx="6" cy="6" r="3" />
                                                                <path d="M6 9v12" />
                                                                <path
                                                                    d="M13 6V4.5C13 3.1 14.1 2 15.5 2S18 3.1 18 4.5V6c0 1.4-1.1 3-2.5 3S13 7.4 13 6z" />
                                                                <path d="M18 9v12" />
                                                            </svg>
                                                            <% } else if (cat==='Spa treatments' ) { %>
                                                                <svg width="28" height="28" viewBox="0 0 24 24"
                                                                    fill="none" stroke="currentColor"
                                                                    stroke-width="1.5">
                                                                    <path
                                                                        d="M12 22c-4.97 0-9-2.24-9-5v-1c0-2.76 4.03-5 9-5s9 2.24 9 5v1c0 2.76-4.03 5-9 5z" />
                                                                    <path d="M12 2s4 3 4 7-4 7-4 7-4-3-4-7 4-7 4-7z" />
                                                                </svg>
                                                                <% } else if (cat==='Catering' ) { %>
                                                                    <svg width="28" height="28" viewBox="0 0 24 24"
                                                                        fill="none" stroke="currentColor"
                                                                        stroke-width="1.5">
                                                                        <rect x="2" y="7" width="20" height="14"
                                                                            rx="2" />
                                                                        <path d="M16 7V5a4 4 0 0 0-8 0v2" />
                                                                        <line x1="12" y1="11" x2="12" y2="17" />
                                                                        <line x1="9" y1="14" x2="15" y2="14" />
                                                                    </svg>
                                                                    <% } else { %>
                                                                        <svg width="28" height="28" viewBox="0 0 24 24"
                                                                            fill="none" stroke="currentColor"
                                                                            stroke-width="1.5">
                                                                            <circle cx="12" cy="12" r="10" />
                                                                            <path d="M12 6v6l4 2" />
                                                                        </svg>
                                                                        <% } %>
                                </div>
                                <span class="service-cat-name">
                                    <%= cat %>
                                </span>
                                <% if (!['Photography'].includes(cat)) { %>
                                    <span class="service-cat-status">Coming soon</span>
                                    <% } else { %>
                                        <span class="service-cat-status" style="color:var(--text-primary);">
                                            <%= categories[cat].length %> available
                                        </span>
                                        <% } %>
                            </a>
                            <% }) %>
                    </div>
                </div>

                <!-- Discover Services -->
                <h2
                    style="font-size:1.5rem; font-weight:700; color:var(--text-primary); margin-bottom:28px; margin-top:12px;">
                    Discover services on Airbnb</h2>

                <% categoryOrder.forEach((cat, i)=> { %>
                    <div class="listing-section" id="section-<%= i %>">
                        <div class="listing-section-header">
                            <h2 class="listing-section-title">
                                <%= cat %>
                                    <a href="#" class="arrow-link">→</a>
                            </h2>
                            <div style="display:flex;gap:6px;">
                                <button
                                    onclick="document.getElementById('svc-row-<%= i %>').scrollBy({left:-260,behavior:'smooth'})"
                                    style="border:1px solid var(--border);width:32px;height:32px;border-radius:50%;background:var(--bg-primary);display:flex;align-items:center;justify-content:center;cursor:pointer;">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2.5">
                                        <polyline points="15 18 9 12 15 6" />
                                    </svg>
                                </button>
                                <button
                                    onclick="document.getElementById('svc-row-<%= i %>').scrollBy({left:260,behavior:'smooth'})"
                                    style="border:1px solid var(--border);width:32px;height:32px;border-radius:50%;background:var(--bg-primary);display:flex;align-items:center;justify-content:center;cursor:pointer;">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2.5">
                                        <polyline points="9 18 15 12 9 6" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="scroll-row-wrapper">
                            <div class="scroll-row" id="svc-row-<%= i %>">
                                <% categories[cat].forEach(svc=> { %>
                                    <div class="listing-card service-card">
                                        <div class="listing-card-image">
                                            <img src="<%= svc.photoUrl %>" alt="<%= svc.serviceName %>"
                                                loading="lazy" />
                                            <% if (svc.isPopular) { %>
                                                <span class="guest-fav-badge">Popular</span>
                                                <% } %>
                                                    <div class="listing-card-heart">
                                                        <button class="heart-btn">
                                                            <svg viewBox="0 0 24 24">
                                                                <path
                                                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                                            </svg>
                                                        </button>
                                                    </div>
                                        </div>
                                        <div class="listing-card-info">
                                            <div class="listing-card-title">
                                                <%= svc.serviceName %>
                                            </div>
                                            <div class="service-card-provider">by <%= svc.provider %>
                                            </div>
                                            <div class="listing-card-meta">
                                                <span>
                                                    <%= svc.location %>
                                                </span>
                                            </div>
                                            <div class="service-card-price">
                                                From ₹<%= svc.price.toLocaleString() %> / guest
                                                    <% if (svc.rating> 0) { %>
                                                        &nbsp;·&nbsp;
                                                        <span class="star">
                                                            <svg viewBox="0 0 24 24">
                                                                <path
                                                                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                                            </svg>
                                                            <%= svc.rating %>
                                                        </span>
                                                        <% } %>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>
                    </div>
                    <% }) %>

            </div>

            <%- include('../partials/footer') %>

                <script>
                    function scrollToSection(e, id) {
                        e.preventDefault();
                        document.getElementById(id).scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                </script>
    </body>

    </html>