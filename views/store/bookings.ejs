<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav') %>

      <div class="page-container">
        <div class="page-header">
          <h2 class="page-title">Your trips</h2>
          <p class="page-subtitle">Upcoming and past reservations</p>
        </div>

        <% if (bookings && bookings.length> 0) { %>
          <div style="display:flex; flex-direction:column; gap:20px;">
            <% bookings.forEach((booking, index)=> { %>
              <div class="booking-item animate-fade-in-up stagger-<%= (index % 6) + 1 %>">
                <div class="booking-item-image">
                  <% if (booking.houseId && booking.houseId.photoUrl) { %>
                    <img src="<%= booking.houseId.photoUrl %>" alt="<%= booking.houseId.houseName %>">
                    <% } else { %>
                      <div
                        style="width:100%;height:100%;background:linear-gradient(135deg,#f0f0f0,#e0e0e0);display:flex;align-items:center;justify-content:center;color:#b0b0b0;">
                        No Image</div>
                      <% } %>
                </div>
                <div class="booking-item-body">
                  <div>
                    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                      <div>
                        <h3 style="font-size:1.125rem; font-weight:600; margin-bottom:2px;">
                          <%= booking.houseId ? booking.houseId.houseName : 'Home no longer available' %>
                        </h3>
                        <% if (booking.houseId) { %>
                          <div class="card-location">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                              <circle cx="12" cy="10" r="3" />
                            </svg>
                            <%= booking.houseId.location %>
                          </div>
                          <% } %>
                      </div>
                      <% if (booking.houseId) { %>
                        <span style="font-weight:600; color:var(--teal); white-space:nowrap;">₹<%=
                            booking.houseId.price.toLocaleString() %> /night</span>
                        <% } %>
                    </div>

                    <div style="display:flex; gap:16px; margin-top:12px; flex-wrap:wrap;">
                      <div class="booking-dates">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                          <line x1="16" y1="2" x2="16" y2="6" />
                          <line x1="8" y1="2" x2="8" y2="6" />
                          <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        <span><strong>Check-in:</strong>
                          <%= new Date(booking.checkIn).toLocaleDateString('en-IN', { day: 'numeric' , month: 'short' ,
                            year: 'numeric' }) %>
                        </span>
                      </div>
                      <div class="booking-dates">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                          <line x1="16" y1="2" x2="16" y2="6" />
                          <line x1="8" y1="2" x2="8" y2="6" />
                          <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        <span><strong>Check-out:</strong>
                          <%= new Date(booking.checkOut).toLocaleDateString('en-IN', { day: 'numeric' , month: 'short' ,
                            year: 'numeric' }) %>
                        </span>
                      </div>
                      <div class="booking-guests">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                          <circle cx="9" cy="7" r="4" />
                        </svg>
                        <span>
                          <%= booking.guests %> guest<%= booking.guests> 1 ? 's' : '' %>
                        </span>
                      </div>
                    </div>
                  </div>

                  <div style="margin-top:16px;">
                    <form action="/bookings/delete/<%= booking._id %>" method="POST">
                      <button type="submit" class="btn btn-danger btn-sm">Cancel reservation</button>
                    </form>
                  </div>
                </div>
              </div>
              <% }) %>
          </div>
          <% } else { %>
            <div class="empty-state">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
              <h3>No trips booked ... yet!</h3>
              <p>Time to dust off your bags and start planning your next adventure.</p>
              <a href="/homes" class="btn btn-primary">Start exploring</a>
            </div>
            <% } %>
      </div>

      <%- include('../partials/footer') %>
  </body>

  </html>