<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav') %>

      <div class="page-container">
        <div class="page-header">
          <h2 class="page-title">Explore all homes</h2>
          <p class="page-subtitle">
            <%= registeredHomes.length %> places to stay
          </p>
        </div>

        <div class="grid grid-4">
          <% registeredHomes.forEach((home, index)=> { %>
            <a href="/homes/<%= home._id %>" style="text-decoration: none; color: inherit;">
              <div class="card animate-fade-in-up stagger-<%= (index % 6) + 1 %>">
                <div class="card-image-wrapper">
                  <% if (home.photoUrl) { %>
                    <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>">
                    <% } else { %>
                      <div class="no-image">No image available</div>
                      <% } %>
                        <div class="card-badge badge-superhost">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                            <path
                              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                          </svg>
                          Superhost
                        </div>
                        <div class="card-heart"
                          onclick="event.preventDefault(); event.stopPropagation(); this.closest('.card-heart').querySelector('form')?.submit();">
                          <%- include('../partials/favourite', {home: home}) %>
                        </div>
                </div>
                <div class="card-body">
                  <div class="card-title">
                    <%= home.houseName %>
                  </div>
                  <div class="card-location">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                    <%= home.location %>
                  </div>
                  <div class="card-meta">
                    <div class="card-price">₹<%= home.price.toLocaleString() %> <span>/ night</span></div>
                    <div class="card-rating">
                      <svg viewBox="0 0 24 24">
                        <path
                          d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                      </svg>
                      <%= home.rating %>
                    </div>
                  </div>
                </div>
              </div>
            </a>
            <% }) %>
        </div>
      </div>

      <%- include('../partials/footer') %>
  </body>

  </html>