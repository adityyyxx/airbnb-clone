<%- include('../partials/head') %>
    </head>

    <body>
        <%- include('../partials/nav') %>

            <div class="page-container" style="max-width: 1100px;">
                <!-- Hero Image -->
                <div class="detail-hero animate-fade-in">
                    <% if (home.photoUrl) { %>
                        <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>">
                        <% } else { %>
                            <div
                                style="width:100%;height:480px;background:linear-gradient(135deg,#f0f0f0,#e0e0e0);display:flex;align-items:center;justify-content:center;color:#b0b0b0;font-size:1.25rem;">
                                No image available</div>
                            <% } %>
                </div>

                <div class="detail-layout">
                    <!-- Left Column — Details -->
                    <div class="animate-fade-in-up">
                        <div
                            style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom: 8px;">
                            <div>
                                <h1 style="font-size:1.75rem; font-weight:700; letter-spacing:-0.5px;">
                                    <%= home.houseName %>
                                </h1>
                                <div class="card-location" style="font-size:1rem; margin-top:4px;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                        <circle cx="12" cy="10" r="3" />
                                    </svg>
                                    <%= home.location %>
                                </div>
                            </div>
                            <div class="card-rating" style="font-size:1rem; gap:6px;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#FFB400">
                                    <path
                                        d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                </svg>
                                <strong>
                                    <%= home.rating %>
                                </strong>
                                <span style="color:var(--text-secondary);">· 24 reviews</span>
                            </div>
                        </div>

                        <!-- Trust Badges -->
                        <div style="display:flex; gap:8px; margin:16px 0 0;">
                            <span class="badge badge-superhost">★ Superhost</span>
                            <span class="badge badge-verified">✓ Verified</span>
                            <span class="badge badge-safety">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                </svg>
                                Safety
                            </span>
                        </div>

                        <!-- Description -->
                        <div class="detail-section">
                            <h3>About this home</h3>
                            <p style="color:var(--text-secondary); line-height:1.7;">
                                <%= home.description
                                    || 'This beautiful property offers an unforgettable experience. Enjoy comfortable amenities, stunning views, and a perfect location for your next getaway.'
                                    %>
                            </p>
                        </div>

                        <!-- Amenities -->
                        <div class="detail-section">
                            <h3>What this place offers</h3>
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:8px;">
                                <div style="display:flex; align-items:center; gap:12px; color:var(--text-secondary);">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="1.5">
                                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                                        <line x1="8" y1="21" x2="16" y2="21" />
                                        <line x1="12" y1="17" x2="12" y2="21" />
                                    </svg>
                                    Wi-Fi
                                </div>
                                <div style="display:flex; align-items:center; gap:12px; color:var(--text-secondary);">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="1.5">
                                        <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z" />
                                    </svg>
                                    Air conditioning
                                </div>
                                <div style="display:flex; align-items:center; gap:12px; color:var(--text-secondary);">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="1.5">
                                        <rect x="2" y="7" width="20" height="15" rx="2" ry="2" />
                                        <polyline points="17 2 12 7 7 2" />
                                    </svg>
                                    Kitchen
                                </div>
                                <div style="display:flex; align-items:center; gap:12px; color:var(--text-secondary);">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="1.5">
                                        <circle cx="12" cy="12" r="10" />
                                        <polyline points="12 6 12 12 16 14" />
                                    </svg>
                                    Free parking
                                </div>
                            </div>
                        </div>

                        <!-- Wishlist -->
                        <div class="detail-section">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <%- include('../partials/favourite') %>
                                    <span style="font-size:0.9375rem; color:var(--text-secondary);">Save to your
                                        wishlist</span>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column — Booking Card -->
                    <div class="animate-fade-in-up stagger-2">
                        <div class="booking-card">
                            <div class="booking-card-price">
                                ₹<%= home.price.toLocaleString() %> <span>/ night</span>
                            </div>

                            <div style="display:flex; align-items:center; gap:6px; margin-bottom:20px;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFB400">
                                    <path
                                        d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                </svg>
                                <strong style="font-size:0.875rem;">
                                    <%= home.rating %>
                                </strong>
                                <span style="color:var(--text-secondary);font-size:0.875rem;">· 24 reviews</span>
                            </div>

                            <% if (isLoggedIn) { %>
                                <form action="/bookings" method="POST">
                                    <input type="hidden" name="houseId" value="<%= home._id %>" />

                                    <div
                                        style="border:1.5px solid var(--border); border-radius:var(--radius-sm); overflow:hidden; margin-bottom:16px;">
                                        <div
                                            style="display:grid; grid-template-columns:1fr 1fr; border-bottom:1.5px solid var(--border);">
                                            <div style="padding:10px 12px; border-right:1.5px solid var(--border);">
                                                <label
                                                    style="display:block; font-size:0.625rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Check-in</label>
                                                <input type="date" name="checkIn" required
                                                    style="border:none;outline:none;font-size:0.875rem;width:100%;font-family:var(--font);color:var(--text-primary);background:transparent;" />
                                            </div>
                                            <div style="padding:10px 12px;">
                                                <label
                                                    style="display:block; font-size:0.625rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Check-out</label>
                                                <input type="date" name="checkOut" required
                                                    style="border:none;outline:none;font-size:0.875rem;width:100%;font-family:var(--font);color:var(--text-primary);background:transparent;" />
                                            </div>
                                        </div>
                                        <div style="padding:10px 12px;">
                                            <label
                                                style="display:block; font-size:0.625rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Guests</label>
                                            <input type="number" name="guests" min="1" max="10" value="1"
                                                style="border:none;outline:none;font-size:0.875rem;width:100%;font-family:var(--font);color:var(--text-primary);background:transparent;" />
                                        </div>
                                    </div>

                                    <button type="submit" class="btn btn-primary btn-full" style="padding:14px;">
                                        Reserve
                                    </button>
                                </form>
                                <% } else { %>
                                    <div style="text-align:center; padding: 20px 0;">
                                        <p style="font-size:0.875rem; color:var(--text-secondary); margin-bottom:16px;">
                                            Please sign in to reserve this home</p>
                                        <a href="/login" class="btn btn-primary btn-full"
                                            style="padding:14px; text-decoration:none;">
                                            Sign in to Reserve
                                        </a>
                                    </div>
                                    <% } %>

                                        <p
                                            style="text-align:center; font-size:0.8125rem; color:var(--text-secondary); margin-top:12px;">
                                            You won't be charged yet</p>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/footer') %>
    </body>

    </html>